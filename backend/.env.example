# Copy to .env and fill in values. NEVER commit .env to git.

# Server
NODE_ENV=development
PORT=3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://travirt:travirt_pass@localhost:5432/travirt_db

# Cache & Sessions (Redis)
REDIS_URL=redis://localhost:6379

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
REFRESH_TOKEN_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_SECRET

# Token lifetimes
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# AI — server-side only, never in frontend
GEMINI_API_KEY=

# Email — Resend (https://resend.com — 3,000 emails/month free)
RESEND_API_KEY=re_...

# Broker — server-side only, never in frontend
# Leave blank in beta — enables virtual-only mode
ALICE_USER_ID=
ALICE_API_KEY=
ALICE_ACCESS_TOKEN=
ALICE_APP_KEY=

# Alice Blue token auto-refresh (optional but strongly recommended for production)
# Obtain ALICE_REFRESH_TOKEN from Alice Blue A3 login; the server will auto-rotate it.
# ALICE_TOKEN_URL defaults to https://a3.aliceblueonline.com/realms/alice/protocol/openid-connect/token
# ALICE_CLIENT_ID defaults to 'web'
ALICE_REFRESH_TOKEN=
ALICE_TOKEN_URL=
ALICE_CLIENT_ID=

# Razorpay payments — leave blank in beta (billing UI disabled)
# Dashboard: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Create subscription plans in Razorpay Dashboard → Subscriptions → Plans
RAZORPAY_PLAN_ID_PRO=
RAZORPAY_PLAN_ID_ELITE=

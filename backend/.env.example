# Copy to .env and fill in values. NEVER commit .env to git.

# Server
NODE_ENV=development
PORT=3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://travirt:travirt_pass@localhost:5432/travirt_db

# Cache & Sessions (Redis)
REDIS_URL=redis://localhost:6379

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
REFRESH_TOKEN_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_SECRET

# Token lifetimes
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# AI — server-side only, never in frontend
GEMINI_API_KEY=

# Broker — server-side only, never in frontend
ALICE_USER_ID=
ALICE_API_KEY=

# Stripe payments (optional — omit to disable payments entirely)
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Dashboard > Developers > Webhooks > signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Dashboard > Products > (create Pro/Elite products) > Price ID
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ELITE=price_...

# Email (Sendgrid or SMTP — Sprint 3)
# SENDGRID_API_KEY=

# Payments (Stripe — Sprint 3)
# STRIPE_SECRET_KEY=

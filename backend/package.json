{
  "name": "travirt-api",
  "version": "1.0.0",
  "description": "TraVirt backend API server",
  "private": true,
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --env-file=.env node_modules/tsx/dist/cli.mjs watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node --env-file=.env node_modules/tsx/dist/cli.mjs src/database/migrate.ts",
    "seed": "node --env-file=.env node_modules/tsx/dist/cli.mjs src/database/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket": "^8.3.1",
    "@google/genai": "^1.52.0",
    "@sentry/node": "^10.59.0",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.26.0",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.10.1",
    "pg": "^8.11.3",
    "pino-pretty": "^10.3.1",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "ws": "^8.21.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.10.9",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^1.6.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  }
}
